# Shared bearer token between Vibal Supabase edge function and this service.
# Generate with: openssl rand -hex 32
WALLET_SIGNING_SERVICE_TOKEN=

# Apple Pass Type ID certificate (PEM). Paste full PEM including
# -----BEGIN CERTIFICATE----- ... -----END CERTIFICATE-----
# In Vercel UI, real newlines are preserved. If you script it via CLI,
# escape newlines as \n and the service will normalize them at runtime.
APPLE_PASS_CERTIFICATE=

# Private key matching the Pass Type ID cert (PEM, encrypted).
APPLE_PASS_PRIVATE_KEY=

# Passphrase for APPLE_PASS_PRIVATE_KEY.
APPLE_PASS_PRIVATE_KEY_PASSPHRASE=

# Apple WWDR intermediate certificate (PEM).
# Download from https://www.apple.com/certificateauthority/
APPLE_WWDR_CERTIFICATE=
